<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>

    <AssemblyName>DeskPulse</AssemblyName>
    <RootNamespace>DeskPulse</RootNamespace>
    <Product>DeskPulse</Product>
    <Title>DeskPulse</Title>
    <Description>DeskPulse - Windows activity monitor</Description>
    <Company>Kai Eysselein</Company>
    <ApplicationIcon>file-logger.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>

    <Version>0.1.3.1</Version>
    <AssemblyVersion>0.1.3.1</AssemblyVersion>
    <FileVersion>0.1.3.1</FileVersion>
    <InformationalVersion>0.1.3.1</InformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.105.0" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.9" />
    <PackageReference Include="Microsoft.Diagnostics.Tracing.TraceEvent" Version="3.2.4" />
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.3" />
  </ItemGroup>

  <ItemGroup>
    <!-- Ignore obsolete Maintenance files that may remain after copying an update over an older checkout. -->
    <Compile Remove="Forms\MaintenanceForm.cs" />
    <Compile Remove="Forms\MaintenanceProgressForm.cs" />
    <Compile Remove="Forms\MaintenanceProgressForm.Designer.cs" />
    <EmbeddedResource Remove="Forms\MaintenanceProgressForm.resx" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="file-logger.ico">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Forms\SettingsForm.Designer.cs">
      <DependentUpon>SettingsForm.cs</DependentUpon>
    </Compile>
    <EmbeddedResource Update="Forms\SettingsForm.resx">
      <DependentUpon>SettingsForm.cs</DependentUpon>
    </EmbeddedResource>
    <Compile Update="Forms\AboutForm.Designer.cs">
      <DependentUpon>AboutForm.cs</DependentUpon>
    </Compile>
    <EmbeddedResource Update="Forms\AboutForm.resx">
      <DependentUpon>AboutForm.cs</DependentUpon>
    </EmbeddedResource>
    <Compile Update="Forms\ExportDateRangeForm.Designer.cs">
      <DependentUpon>ExportDateRangeForm.cs</DependentUpon>
    </Compile>
    <EmbeddedResource Update="Forms\ExportDateRangeForm.resx">
      <DependentUpon>ExportDateRangeForm.cs</DependentUpon>
    </EmbeddedResource>
    <Compile Update="Forms\InstalledAppSelectionForm.Designer.cs">
      <DependentUpon>InstalledAppSelectionForm.cs</DependentUpon>
    </Compile>
    <EmbeddedResource Update="Forms\InstalledAppSelectionForm.resx">
      <DependentUpon>InstalledAppSelectionForm.cs</DependentUpon>
    </EmbeddedResource>
    <Compile Update="Forms\ViewLogForm.Designer.cs">
      <DependentUpon>ViewLogForm.cs</DependentUpon>
    </Compile>
    <EmbeddedResource Update="Forms\ViewLogForm.resx">
      <DependentUpon>ViewLogForm.cs</DependentUpon>
    </EmbeddedResource>
    <Compile Update="Forms\LogEntryDetailsForm.Designer.cs">
      <DependentUpon>LogEntryDetailsForm.cs</DependentUpon>
    </Compile>
    <EmbeddedResource Update="Forms\LogEntryDetailsForm.resx">
      <DependentUpon>LogEntryDetailsForm.cs</DependentUpon>
    </EmbeddedResource>
    <Compile Update="Forms\RuleCleanupProgressForm.Designer.cs">
      <DependentUpon>RuleCleanupProgressForm.cs</DependentUpon>
    </Compile>
    <EmbeddedResource Update="Forms\RuleCleanupProgressForm.resx">
      <DependentUpon>RuleCleanupProgressForm.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>

</Project>